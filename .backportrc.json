{
  "repoOwner": "karmada-io",
  "repoName": "karmada",
  "targetBranchChoices": [],
  "branchLabelMapping": {
    "^backport-to-(.+)$": "$1"
  },
  "targetBranches": [],
  "sourceBranch": "master",
  "prTitle": "[{{targetBranch}}] Automated cherry pick of #{{sourcePullRequest.number}}: {{sourcePullRequest.title}}",
  "prDescription": "Cherry pick of #{{sourcePullRequest.number}} on {{targetBranch}}.\n\n### Original PR Body\n\n> {{sourcePullRequest.body}}\n\n**Note:** If this cherry pick had conflicts, conflict markers will be present in the changed files. Please review carefully.\n\nFor details on the cherry pick process, see the [cherry pick requests](https://karmada.io/docs/contributor/cherry-picks) page.",
  "backportBranchName": "backport/{{targetBranch}}/{{refValues}}",
  "targetPRLabels": ["backport"],
  "sourcePRLabels": [],
  "copySourcePRLabels": false,
  "assignees": [],
  "autoAssign": false,
  "reviewers": [],
  "copySourcePRReviewers": false,
  "autoMerge": false,
  "autoMergeMethod": "merge",
  "commitConflicts": true,
  "autoResolveConflictsWithTheirs": false,
  "publishStatusCommentOnSuccess": true,
  "publishStatusCommentOnFailure": true,
  "publishStatusCommentOnAbort": true,
  "author": null,
  "prFilter": "",
  "commitPaths": [],
  "dateSince": null,
  "dateUntil": null,
  "fork": false,
  "mainline": null,
  "resetAuthor": false,
  "signoff": false,
  "dir": "~/.backport/repositories/",
  "maxNumber": 10,
  "multipleCommits": false,
  "multipleBranches": true,
  "backportBinary": "backport",
  "gitHostname": "github.com",
  "githubApiBaseUrlV3": "https://api.github.com",
  "githubApiBaseUrlV4": "https://api.github.com/graphql"
}
